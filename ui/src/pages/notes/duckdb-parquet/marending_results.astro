---
import Chart from 'src/components/Chart.astro';
import { Figure } from 'src/components/Figure';
import * as Plot from '@observablehq/plot';

let results = [
	{ type: 'json', query: 'errors', duration: 140 },
	{ type: 'json', query: 'traffic', duration: 185 },
	{ type: 'map', query: 'errors', duration: 150 },
	{ type: 'map', query: 'traffic', duration: 197 },
	{ type: 'variant', query: 'errors', duration: 900 },
	{ type: 'variant', query: 'traffic', duration: 950 },
	{ type: 'materialized', query: 'errors', duration: 10 },
	{ type: 'materialized', query: 'traffic', duration: 77 },
];
---

<Figure caption="Figure 2. Duration of access log queries against different Parquet files">
	<Chart
		options={{
    		marginRight: 80,
    		marginLeft: 80,
			x: { grid: true, label: '→ duration (ms)', domain: [0,1000] },
			y: { inset: 2, label: null },
			marks: [
				Plot.frame(),
				Plot.barX(results, {
					x: 'duration',
					y: 'type',
					fy: 'query',
				}),
				Plot.text(results, {
					text: (d) => `${Math.floor(d.duration)}`,
					y: 'type',
					x: 'duration',
					textAnchor: 'start',
					dx: 2,
					fill: 'black',
					fy: 'query',
				}),
			],
		}}
	/>
</Figure>
